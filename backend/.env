# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:DB_HomeEase@localhost:5432/homeease_db"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Email (for OTP/password reset - use your service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@homeease.com

# Payment Gateway (Stripe or Razorpay)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# API Keys
FIREBASE_API_KEY=your_firebase_key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:5173