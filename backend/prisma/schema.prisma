// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  CLIENT
  WORKER
  ADMIN
}

enum TokenType {
  ACCESS
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  QUOTE_SUBMITTED
  QUOTE_APPROVED
  DISPUTED
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  APPROVED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum PaymentMethodType {
  GCASH
  MAYA
  CARD
  BANK_TRANSFER
  CASH
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum KycDocumentType {
  GOVERNMENT_ID_FRONT
  GOVERNMENT_ID_BACK
  SELFIE
  RESUME
  CERTIFICATION
}

enum KycDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContractType {
  WORKER_SERVICE_AGREEMENT
  CLIENT_USER_AGREEMENT
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  BOOKING_COMPLETED
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
  ADDON_ADDED
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
  VERIFICATION_EMAIL
  PASSWORD_RESET
  QUOTE_SUBMITTED
  QUOTE_APPROVED
  QUOTE_DISPUTED
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id         String  @id @default(cuid())
  email      String  @unique
  phone      String?
  password   String
  fullName   String
  role       Role
  isVerified Boolean @default(false)
  avatar     String?
  notificationPreferences Json?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile       ClientProfile?
  workerProfile       WorkerProfile?
  addresses           UserAddress[]
  sentMessages        Message[]           @relation("sender")
  receivedMessages    Message[]           @relation("receiver")
  bookingsAsClient    Booking[]           @relation("client")
  bookingsAsWorker    Booking[]           @relation("worker")
  reviews             Review[]
  notifications       Notification[]
  authTokens          AuthToken[]
  kycDocuments        KycDocument[]
  contractAcceptances ContractAcceptance[]

  @@index([email])
  @@index([role])
  @@index([isDeleted])
}

model UserAddress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String?
  street    String
  city      String
  state     String?
  zipCode   String?
  isDefault Boolean @default(false)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// ============================================================================
// PROFILES
// ============================================================================

model ClientProfile {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  address  String?
  city     String?
  state    String?
  zipCode  String?

  // Relations
  paymentMethods SavedPaymentMethod[]

  @@index([userId])
}

model WorkerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio          String?
  rating       Float   @default(5.0)
  totalReviews Int     @default(0)

  // Availability & Capacity
  isAvailable        Boolean @default(true)
  maxConcurrentJobs  Int     @default(2)
  activeJobCount     Int     @default(0)
  availableDays      Int[]   @default([1, 2, 3, 4, 5]) // 0=Sun, 1=Mon ... 6=Sat
  serviceAreaRadius  Int     @default(30) // in kilometers

  // Location
  address String?
  city    String?
  state   String?
  zipCode String?

  // KYC
  kycStatus      KYCStatus @default(PENDING)
  kycSubmittedAt DateTime?
  kycApprovedAt  DateTime?

  // Resume file URL (raw file)
  resumeUrl String?

  // Relations
  serviceTypes      ServiceType[]
  certifications    Certification[]
  reviews           Review[]
  resumeParseResult ResumeParseResult?

  @@index([userId])
  @@index([kycStatus])
  @@index([isAvailable])
}

// ============================================================================
// KYC & DOCUMENTS
// ============================================================================

model KycDocument {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentType KycDocumentType
  fileUrl      String
  fileSize     Int?
  mimeType     String?

  status          KycDocumentStatus @default(PENDING)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, documentType])
  @@index([status])
}

model ResumeParseResult {
  id              String        @id @default(cuid())
  workerProfileId String        @unique
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  rawText           String?
  parsedSkills      String[]
  yearsOfExperience Int?
  masteryLevel      String?
  tradeCategory     String?
  summary           String?

  parsedAt   DateTime @default(now())
  modelUsed  String   @default("claude-sonnet-4-6")

  @@index([workerProfileId])
}

model Certification {
  id              String        @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  title       String
  issuer      String
  issueDate   DateTime
  expiryDate  DateTime?
  documentUrl String

  // Verification tracking
  verificationStatus KycDocumentStatus @default(PENDING)
  rejectionReason    String?
  reviewedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerProfileId])
  @@index([verificationStatus])
}

// ============================================================================
// LEGAL
// ============================================================================

model ContractAcceptance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contractType    ContractType
  contractVersion String       @default("1.0")
  acceptedAt      DateTime     @default(now())
  ipAddress       String?
  userAgent       String?

  @@index([userId, contractType])
}

// ============================================================================
// SERVICES
// ============================================================================

model ServiceType {
  id          String  @id @default(cuid())
  name        String
  description String?
  basePrice   Float
  isActive    Boolean @default(true)

  // Relations
  workers WorkerProfile[]
  tasks   ServiceTask[]

  @@unique([name])
}

model ServiceTask {
  id            String      @id @default(cuid())
  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  basePrice       Float
  durationHours   Float
  isActive        Boolean @default(true)

  // Relations
  bookings Booking[]

  @@index([serviceTypeId])
}

// ============================================================================
// BOOKINGS
// ============================================================================

model Booking {
  id String @id @default(cuid())

  // Parties
  clientId String
  client   User   @relation("client", fields: [clientId], references: [id], onDelete: Cascade)
  workerId String
  worker   User   @relation("worker", fields: [workerId], references: [id], onDelete: Cascade)

  // Service
  serviceType             String
  serviceTaskId           String?
  serviceTask             ServiceTask? @relation(fields: [serviceTaskId], references: [id])
  description             String
  estimatedDurationHours  Float?

  // Scheduling
  scheduledDate  DateTime
  completionDate DateTime?

  // Status
  status BookingStatus @default(PENDING)

  // Pricing — initial estimate
  estimatedPrice Float
  tip            Float?  @default(0)

  // Quote lifecycle
  quoteStatus   QuoteStatus?
  laborCost     Float?
  materialsCost Float?
  quotedAt      DateTime?
  quoteNotes    String?
  approvedAt    DateTime?
  disputeReason String?

  // Inspection fee
  inspectionFeeCharged Boolean @default(false)
  inspectionFeeAmount  Float?

  // Final
  finalPrice Float?

  // Location
  location String
  city     String
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  payment  Payment?
  review   Review?
  addOns   BookingAddOn[]

  @@index([clientId, status])
  @@index([workerId, status])
  @@index([scheduledDate])
  @@index([status])
}

model BookingAddOn {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  name  String
  price Float

  @@index([bookingId])
}

// ============================================================================
// PAYMENTS
// ============================================================================

model Payment {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // Amounts
  subtotal     Float
  tip          Float  @default(0)

  // Commission
  commissionRate   Float @default(0.10)
  commissionAmount Float

  // Withholding tax (BIR compliance for professional fees)
  withholdingTaxRate   Float @default(0.05)
  withholdingTaxAmount Float

  // Worker receives
  workerPayout Float

  // Total charged to client
  totalAmount Float

  // Status
  status       PaymentStatus @default(PENDING)
  escrowStatus EscrowStatus  @default(HELD)
  releasedAt   DateTime?

  // PayMongo references
  paymongoPaymentId String?
  paymongoSourceId  String?

  // Payment method used
  methodType         PaymentMethodType
  accountIdentifier  String? // masked GCash number, last 4 of card, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  @@index([escrowStatus])
}

model SavedPaymentMethod {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  type              PaymentMethodType
  accountIdentifier String?  // masked — last 4 digits or masked phone number
  label             String?  // e.g. "My GCash", "Work Card"
  isDefault         Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([clientProfileId])
}

// ============================================================================
// REVIEWS
// ============================================================================

model Review {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  workerId String
  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  clientId String
  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  rating  Float   // 1.0 to 5.0
  comment String?

  createdAt DateTime @default(now())

  @@index([workerId])
  @@index([clientId])
}

// ============================================================================
// MESSAGING
// ============================================================================

model Message {
  id         String @id @default(cuid())
  senderId   String
  sender     User   @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  content String
  isRead  Boolean   @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String
  relatedId String?
  isRead    Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
}